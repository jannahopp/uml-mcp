@startuml
node "Load Balancer" {
  artifact "nginx"
}
node "App Server 1" {
  artifact "app.war"
}
node "App Server 2" {
  artifact "app.war"
}
node "Database Server" {
  database "MySQL"
}
"Load Balancer" --> "App Server 1"
"Load Balancer" --> "App Server 2"
"App Server 1" --> "Database Server"
"App Server 2" --> "Database Server"
@enduml