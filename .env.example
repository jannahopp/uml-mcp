# Copy to .env and adjust. Do not commit .env.
# See docs/configuration.md for full options.

# Output directory for generated diagrams
# MCP_OUTPUT_DIR=./output

# Kroki (default: https://kroki.io)
# KROKI_SERVER=https://kroki.io
# USE_LOCAL_KROKI=false

# PlantUML (default: http://plantuml-server:8080)
# PLANTUML_SERVER=http://plantuml-server:8080
# USE_LOCAL_PLANTUML=false

# Optional
# LOG_LEVEL=INFO
# LIST_TOOLS=false
