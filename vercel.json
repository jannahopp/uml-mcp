{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt && python scripts/generate_server_card.py",
  "installCommand": "pip install --upgrade pip",
  "framework": null,
  "functions": {
    "app.py": {
      "maxDuration": 800
    }
  },
  "rewrites": [
    { "source": "/.well-known/mcp/server-card.json", "destination": "/public/.well-known/mcp/server-card.json" },
    { "source": "/.well-known/mcp/config-schema.json", "destination": "/public/.well-known/mcp/config-schema.json" },
    { "source": "/mcp", "destination": "/app.py" },
    { "source": "/mcp/(.*)", "destination": "/app.py" },
    { "source": "/(.*)", "destination": "/app.py" }
  ],
  "env": {
    "KROKI_SERVER": "https://kroki.io",
    "VERCEL_OUTPUT_DIR": "/tmp/diagrams",
    "MCP_OUTPUT_DIR": "/tmp/diagrams",
    "FASTMCP_STATELESS_HTTP": "true"
  }
}
